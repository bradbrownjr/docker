# Copy this file to .env and fill in your values
# cp .env.example .env

# HuggingFace token — required to download Flux models
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Which Flux model(s) to download on first run: schnell, dev, or schnell,dev
# schnell = fast (~4 steps), dev = higher quality (~20 steps), both = ~24GB download
FLUX_MODELS=schnell

# Set to true if you have <24GB VRAM (uses FP8 quantized models)
LOW_VRAM=false
