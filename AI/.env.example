# ==============================================================================\n# AI Stack — Environment Variables\n# Copy this file to .env and fill in your values:\n#   cp .env.example .env\n# ==============================================================================\n\n# ------------------------------------------------------------------------------\n# Hugging Face token — used for ComfyUI model downloads if needed.\n# Get one at: https://huggingface.co/settings/tokens\n# ------------------------------------------------------------------------------\nHF_TOKEN=your_huggingface_token_here\n\n# ------------------------------------------------------------------------------\n# Low VRAM mode for ComfyUI\n#   false  — default, full VRAM usage\n#   true   — enable if you have less than ~8 GB VRAM\n# ------------------------------------------------------------------------------\nLOW_VRAM=false