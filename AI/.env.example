# ==============================================================================\n# AI Stack — Environment Variables\n# Copy this file to .env and fill in your values:\n#   cp .env.example .env\n# ==============================================================================\n\n# ------------------------------------------------------------------------------\n# Hugging Face token — required for ComfyUI to download Flux model weights.\n# Get one at: https://huggingface.co/settings/tokens\n# ------------------------------------------------------------------------------\nHF_TOKEN=your_huggingface_token_here\n\n# ------------------------------------------------------------------------------\n# ComfyUI / Flux model variant\n#   schnell  — fast inference, lower quality (default)\n#   dev      — slower, higher quality (requires HF access approval)\n# ------------------------------------------------------------------------------\nFLUX_MODELS=schnell\n\n# ------------------------------------------------------------------------------\n# Low VRAM mode for ComfyUI\n#   false  — default, full VRAM usage\n#   true   — enable if you have less than ~12 GB VRAM\n# ------------------------------------------------------------------------------\nLOW_VRAM=false