# ==============================================================================
# AI Stack — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Hugging Face — used for ComfyUI model downloads and Odysseus cookbook models
# Get a token at: https://huggingface.co/settings/tokens
# ------------------------------------------------------------------------------
HF_TOKEN=

# ------------------------------------------------------------------------------
# ComfyUI VRAM mode
#   false  — default, full VRAM usage
#   true   — enable if you have less than ~8 GB VRAM
# ------------------------------------------------------------------------------
LOW_VRAM=false

# ------------------------------------------------------------------------------
# Ollama — model serving behaviour
# ------------------------------------------------------------------------------
# How long a model stays loaded in VRAM after last use
#   5m = 5 minutes (default), 0 = unload immediately, -1 = keep forever
OLLAMA_KEEP_ALIVE=5m
# Maximum number of models loaded simultaneously (0 = auto / VRAM-limited)
OLLAMA_MAX_LOADED_MODELS=0
# Parallel inference requests per model (increase if you have VRAM headroom)
OLLAMA_NUM_PARALLEL=1
# Flash-attention optimisation — 1 to enable (faster on Ampere+ GPUs)
OLLAMA_FLASH_ATTENTION=0

# ------------------------------------------------------------------------------
# SearXNG secret key (auto-generated on first boot if left blank)
# ------------------------------------------------------------------------------
SEARXNG_SECRET=

# ------------------------------------------------------------------------------
# Odysseus (--profile odysseus)
# ------------------------------------------------------------------------------
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=

# API keys for Odysseus research tools (all optional)
OPENAI_API_KEY=
DATA_BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_PSE_CX=
TAVILY_API_KEY=
SERPER_API_KEY=

# Odysseus data / log directories (defaults to ./odysseus-data and ./odysseus-logs)
APP_DATA_DIR=
APP_LOGS_DIR=

# Odysseus bind / port (defaults to 127.0.0.1:7000)
APP_BIND=127.0.0.1
APP_PORT=7000

# ChromaDB bind (defaults to 127.0.0.1:8100)
CHROMADB_BIND=127.0.0.1

# ntfy bind and base URL (defaults to 127.0.0.1:8091)
NTFY_BIND=127.0.0.1
NTFY_BASE_URL=http://localhost:8091

# Host user UID/GID for Odysseus file ownership (find yours with: id -u / id -g)
PUID=1000
PGID=1000

# ------------------------------------------------------------------------------
# Hermes Agent (--profile hermes)
# A self-improving AI agent with messaging platform integrations
# ------------------------------------------------------------------------------
# LLM provider — OpenRouter gives access to 200+ models
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Point Hermes at your local Ollama instead of (or in addition to) a cloud provider
HERMES_OLLAMA_URL=http://localhost:11434
# Messaging platform tokens (all optional — only needed for the gateway)
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
# Dashboard port (default: 9119)
HERMES_DASHBOARD_PORT=9119
# UID/GID that owns hermes-data/ on the host (find yours with: id -u / id -g)
HERMES_UID=1000
HERMES_GID=1000
